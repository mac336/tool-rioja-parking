# Variables del frontend (Vite). SOLO claves públicas — NUNCA service_role aquí.
# Copia este archivo a .env.local y rellena con los valores de tu proyecto Supabase.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=tu-anon-key-local

# Captcha (Cloudflare Turnstile) para el formulario público de solicitud de acceso.
# En desarrollo se puede usar la clave de test pública de Turnstile:
#   1x00000000000000000000AA (siempre pasa)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Modo de datos: 'mock' usa src/mock/data.json; 'supabase' usa el backend real.
VITE_DATA_SOURCE=mock
